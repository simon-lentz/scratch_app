# CheckPlan — environment configuration (TEMPLATE).
#
# Copy to `.env` (which is gitignored) and fill in the values from the Supabase
# dashboard (Project Settings → API / Database). NEVER commit the real `.env`.
#
# The client build injects ONLY the URL + publishable key (via `--dart-define`).
# The secret key and DB credentials are tooling-only and must never reach the
# app or the repo.

# --- Client config (public by design — passed to the app via --dart-define) ---

# Project API URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable key (public: RLS protects the data, not this key). New key type
# (`sb_publishable_…`), not the legacy `anon` JWT.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Tooling only (NEVER ship in the client build; keep local) ---

# Service-role-equivalent secret key: migrations + admin API (e.g. account
# deletion). Treat like a password.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Direct Postgres connection string (migrations / psql).
SUPABASE_DB_DIRECT_CONN=postgresql://postgres:[YOUR_DB_PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Database password.
SUPABASE_PW=YOUR_DB_PASSWORD

# JWKS endpoint (for server-side JWT verification, if ever needed).
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
