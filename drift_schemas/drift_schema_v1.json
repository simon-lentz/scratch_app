        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"checklists\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"title\" TEXT NOT NULL, \"color_value\" INTEGER NULL, \"position\" INTEGER NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL, \"archived_at\" TEXT NULL);"
        }
      ]
    },
    {
      "name": "tasks",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"tasks\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"checklist_id\" INTEGER NOT NULL REFERENCES checklists (id) ON DELETE CASCADE, \"title\" TEXT NOT NULL, \"notes\" TEXT NULL, \"is_done\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_done\" IN (0, 1)), \"due_day\" INTEGER NULL, \"position\" INTEGER NOT NULL, \"created_at\" TEXT NOT NULL, \"updated_at\" TEXT NOT NULL);"
        }
      ]
    },
